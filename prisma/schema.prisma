generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  SALES_EXECUTIVE
}

enum SeasonType {
  PEAK
  MODERATE
  OFF
}

enum QuotationStatus {
  DRAFT
  FINALIZED
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotations Quotation[]
}

model State {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  locations Location[]
  packages  TourPackage[]
}

model Location {
  id        Int      @id @default(autoincrement())
  stateId   Int
  name      String
  createdAt DateTime @default(now())

  state  State   @relation(fields: [stateId], references: [id], onDelete: Cascade)
  hotels Hotel[]

  tourPackageLocations TourPackageLocation[]
}

model TourPackage {
  id        Int      @id @default(autoincrement())
  stateId   Int
  name      String
  createdAt DateTime @default(now())

  state      State                 @relation(fields: [stateId], references: [id], onDelete: Cascade)
  locations  TourPackageLocation[]
  quotations Quotation[]
}

model TourPackageLocation {
  id             Int @id @default(autoincrement())
  tourPackageId  Int
  locationId     Int
  numberOfNights Int
  sequenceOrder  Int

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
  location    Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  quotationHotels QuotationHotel[]
}

model HotelCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  hotels Hotel[]
}

model MealPlan {
  id   Int    @id @default(autoincrement())
  name String @unique

  pricing         HotelPricing[]
  quotationHotels QuotationHotel[]
}

model Hotel {
  id         Int      @id @default(autoincrement())
  locationId Int
  categoryId Int
  name       String
  createdAt  DateTime @default(now())

  location Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  category HotelCategory @relation(fields: [categoryId], references: [id])

  pricing         HotelPricing[]
  quotationHotels QuotationHotel[]
}

model Season {
  id        Int        @id @default(autoincrement())
  name      SeasonType @unique
  startDate DateTime
  endDate   DateTime

  pricing         HotelPricing[]
  quotationHotels QuotationHotel[]
}

model HotelPricing {
  id            Int     @id @default(autoincrement())
  hotelId       Int
  seasonId      Int
  mealPlanId    Int
  pricePerNight Decimal @db.Decimal(10, 2)

  hotel    Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  season   Season   @relation(fields: [seasonId], references: [id])
  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id])

  @@unique([hotelId, seasonId, mealPlanId])
}

model Quotation {
  id              Int      @id @default(autoincrement())
  quotationNumber String   @unique
  tourPackageId   Int
  createdById     Int
  travelDate      DateTime

  hotelTotal   Decimal @db.Decimal(12, 2)
  vehicleCost  Decimal @db.Decimal(12, 2)
  activityCost Decimal @db.Decimal(12, 2)

  baseTotal    Decimal @db.Decimal(12, 2)
  profitAmount Decimal @db.Decimal(12, 2)
  gstAmount    Decimal @db.Decimal(12, 2)

  finalTotal    Decimal  @db.Decimal(12, 2)
  overrideTotal Decimal? @db.Decimal(12, 2)

  status QuotationStatus @default(DRAFT)

  createdAt DateTime @default(now())

  tourPackage TourPackage @relation(fields: [tourPackageId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  hotels QuotationHotel[]
}

model QuotationHotel {
  id                    Int @id @default(autoincrement())
  quotationId           Int
  tourPackageLocationId Int
  hotelId               Int
  seasonId              Int
  mealPlanId            Int

  numberOfRooms Int
  nights        Int

  pricePerNight      Decimal @db.Decimal(10, 2)
  customExtraPerRoom Decimal @db.Decimal(10, 2)
  total              Decimal @db.Decimal(12, 2)

  quotation           Quotation           @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  tourPackageLocation TourPackageLocation @relation(fields: [tourPackageLocationId], references: [id])
  hotel               Hotel               @relation(fields: [hotelId], references: [id])
  season              Season              @relation(fields: [seasonId], references: [id])
  mealPlan            MealPlan            @relation(fields: [mealPlanId], references: [id])
}
